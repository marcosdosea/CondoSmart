@model IEnumerable<CondosmartWeb.Models.MoradorViewModel>
@{
    ViewData["Title"] = "Moradores";
}

<div class="cs-page-heading">
    <div>
        <h2 class="fw-bold mb-0"><i class="bi bi-people me-2" aria-hidden="true"></i>Moradores</h2>
        <small class="text-muted">Gerencie os moradores cadastrados</small>
    </div>

    <a asp-action="Create" class="btn btn-cs-primary">
        <i class="bi bi-plus-lg me-1" aria-hidden="true"></i>Novo Morador
    </a>
</div>

<div class="cs-card">
    <div class="cs-card-header d-flex justify-content-between align-items-center">
        <span>Lista</span>
        <span class="text-muted small">Total: @Model.Count()</span>
    </div>

    <div class="cs-card-body">
        @if (TempData["ProvisioningMessage"] is string mensagem)
        {
            var statusEmail = TempData["ProvisioningStatus"]?.ToString();
            var senhaTemporaria = TempData["ProvisioningPassword"]?.ToString();
            var email = TempData["ProvisioningEmail"]?.ToString();
            var link = TempData["ProvisioningLink"]?.ToString();
            var aviso = TempData["ProvisioningWarning"]?.ToString();

            <div class="alert @(statusEmail == "enviado" ? "alert-success" : "alert-warning") border mb-4">
                <strong>@mensagem</strong>
                <div class="small mt-2">Login: @email</div>
                <div class="small">Senha temporaria: <strong>@senhaTemporaria</strong></div>
                <div class="small">Link de acesso: @link</div>
                @if (statusEmail == "enviado")
                {
                    <div class="small mt-2">O e-mail de boas-vindas foi enviado com sucesso.</div>
                }
                else
                {
                    <div class="small mt-2">O cadastro foi concluido, mas o e-mail nao foi enviado automaticamente.</div>
                    @if (!string.IsNullOrWhiteSpace(aviso))
                    {
                        <div class="small">Motivo: @aviso</div>
                    }
                }
            </div>
        }

        @if (!Model.Any())
        {
            <div class="alert alert-info text-center mb-0">
                Nenhum morador cadastrado.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 js-data-table">
                    <thead class="table-light">
                        <tr>
                            <th>Nome</th>
                            <th>CPF</th>
                            <th>Telefone</th>
                            <th>Cidade</th>
                            <th>UF</th>
                            <th class="text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Nome</td>
                                <td>@item.Cpf</td>
                                <td>@(string.IsNullOrEmpty(item.Telefone) ? "—" : item.Telefone)</td>
                                <td>@(string.IsNullOrEmpty(item.Cidade) ? "—" : item.Cidade)</td>
                                <td>@(string.IsNullOrEmpty(item.Uf) ? "—" : item.Uf)</td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-cs-outline me-1" title="Detalhes"><i class="bi bi-eye" aria-hidden="true"></i></a>

                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-cs-outline me-1" title="Editar"><i class="bi bi-pencil" aria-hidden="true"></i></a>

                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-danger" title="Excluir"><i class="bi bi-trash" aria-hidden="true"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
