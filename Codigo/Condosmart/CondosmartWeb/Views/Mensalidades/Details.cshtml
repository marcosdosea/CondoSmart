@model CondosmartWeb.Models.MensalidadeViewModel

@{
    ViewData["Title"] = "Detalhes da mensalidade";
}

@functions {
    private static string StatusClass(string status)
    {
        return status switch
        {
            "pago" => "text-bg-success",
            "pendente" => "text-bg-warning",
            "atrasado" => "text-bg-danger",
            _ => "text-bg-secondary"
        };
    }
}

<div class="cs-page-heading">
    <div>
        <h2 class="fw-bold mb-0"><i class="bi bi-receipt me-2" aria-hidden="true"></i>Detalhes da mensalidade</h2>
        <small class="text-muted">Visualizacao completa da parcela gerada.</small>
    </div>
    <a asp-action="Index" class="btn btn-cs-outline">Voltar</a>
</div>

<div class="cs-card">
    <div class="cs-card-header d-flex justify-content-between align-items-center">
        <span>Mensalidade #@Model.Id</span>
        <span class="badge @StatusClass(Model.Status)">@Model.Status</span>
    </div>
    <div class="cs-card-body">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="border rounded-4 p-3 h-100">
                    <div class="small text-muted mb-1">Morador</div>
                    <div class="fw-semibold">@(Model.MoradorNome ?? "-")</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="border rounded-4 p-3 h-100">
                    <div class="small text-muted mb-1">Unidade</div>
                    <div class="fw-semibold">@(Model.UnidadeIdentificador ?? "-")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded-4 p-3 h-100">
                    <div class="small text-muted mb-1">Competencia</div>
                    <div class="fw-semibold">@Model.Competencia.ToString("MM/yyyy")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded-4 p-3 h-100">
                    <div class="small text-muted mb-1">Vencimento</div>
                    <div class="fw-semibold">@Model.Vencimento.ToString("dd/MM/yyyy")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded-4 p-3 h-100">
                    <div class="small text-muted mb-1">Data de pagamento</div>
                    <div class="fw-semibold">@(Model.DataPagamento?.ToString("dd/MM/yyyy") ?? "-")</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="border rounded-4 p-3 h-100">
                    <div class="small text-muted mb-1">Valor original</div>
                    <div class="fw-semibold text-primary">@Model.ValorOriginal.ToString("C")</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="border rounded-4 p-3 h-100">
                    <div class="small text-muted mb-1">Valor final</div>
                    <div class="fw-semibold text-primary">@Model.ValorFinal.ToString("C")</div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">
            @* TODO: implementar pagamento *@
            <button type="button" class="btn btn-outline-secondary" disabled>Pagar</button>
            <a asp-action="Index" class="btn btn-cs-primary">Voltar para lista</a>
        </div>
    </div>
</div>
