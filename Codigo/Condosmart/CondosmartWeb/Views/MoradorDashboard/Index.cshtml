@model CondosmartWeb.Models.MoradorDashboardViewModel

@{
    ViewData["Title"] = "Meu painel";
}

@functions {
    private static string StatusClass(string status)
    {
        return status?.ToLowerInvariant() switch
        {
            "pago" => "text-bg-success",
            "atrasado" => "text-bg-danger",
            "pendente" => "text-bg-warning",
            _ => "text-bg-secondary"
        };
    }
}

<section class="cs-page-heading">
    <div>
        <span class="cs-eyebrow">&Aacute;rea do morador</span>
        <h2>Meu painel</h2>
        <small>Acompanhe seus dados, sua unidade, mensalidades e comunicados do condom&iacute;nio.</small>
    </div>
</section>

<div class="row g-4 mb-4" id="meus-dados">
    <div class="col-md-6 col-xl-3">
        <div class="cs-kpi-card h-100">
            <div class="cs-kpi-icon"><i class="bi bi-person-badge"></i></div>
            <div>
                <div class="cs-kpi-value">@Model.Nome</div>
                <div class="cs-kpi-label">@Model.Email</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="cs-kpi-card h-100">
            <div class="cs-kpi-icon"><i class="bi bi-buildings"></i></div>
            <div>
                <div class="cs-kpi-value">@Model.Condominio</div>
                <div class="cs-kpi-label">Condom&iacute;nio vinculado</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="cs-kpi-card h-100">
            <div class="cs-kpi-icon"><i class="bi bi-house-door"></i></div>
            <div>
                <div class="cs-kpi-value">@Model.Unidade</div>
                <div class="cs-kpi-label">Unidade residencial</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="cs-kpi-card h-100">
            <div class="cs-kpi-icon"><i class="bi bi-receipt"></i></div>
            <div>
                <div class="cs-kpi-value">@Model.MensalidadesPendentes</div>
                <div class="cs-kpi-label">Mensalidades pendentes</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-8" id="minhas-mensalidades">
        <div class="cs-card h-100">
            <div class="cs-card-header d-flex align-items-center justify-content-between">
                <span>Minhas mensalidades</span>
                <span class="badge text-bg-light">@Model.Mensalidades.Count registro(s)</span>
            </div>
            <div class="cs-card-body">
                @if (Model.Mensalidades.Count == 0)
                {
                    <div class="alert alert-light border mb-0">
                        Nenhuma mensalidade encontrada para o seu cadastro.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Compet&ecirc;ncia</th>
                                    <th>Valor</th>
                                    <th>Vencimento</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var mensalidade in Model.Mensalidades)
                                {
                                    <tr>
                                        <td>@mensalidade.Competencia</td>
                                        <td>@mensalidade.Valor</td>
                                        <td>@mensalidade.Vencimento</td>
                                        <td>
                                            <span class="badge @StatusClass(mensalidade.Status)">
                                                @mensalidade.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-xl-4" id="comunicados">
        <div class="cs-card h-100">
            <div class="cs-card-header">Comunicados</div>
            <div class="cs-card-body">
                @if (Model.Comunicados.Count == 0)
                {
                    <div class="alert alert-light border mb-0">
                        Nenhum comunicado publicado para o seu condom&iacute;nio.
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var comunicado in Model.Comunicados)
                        {
                            <article class="border rounded-4 p-3 bg-light">
                                <div class="d-flex align-items-center justify-content-between gap-3 mb-2">
                                    <strong>@comunicado.Titulo</strong>
                                    <small class="text-muted">@comunicado.Data</small>
                                </div>
                                <p class="mb-0 text-muted">@comunicado.Resumo</p>
                            </article>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
