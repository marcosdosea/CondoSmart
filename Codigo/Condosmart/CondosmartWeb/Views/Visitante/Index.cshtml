@model IEnumerable<CondosmartWeb.Models.VisitanteViewModel>
@{
    ViewData["Title"] = "Visitantes";
}

<div class="cs-page-heading">
    <div>
        <h2 class="fw-bold mb-0"><i class="bi bi-person-check me-2" aria-hidden="true"></i>Visitantes</h2>
        <small class="text-muted">Gerencie os visitantes cadastrados</small>
    </div>

    <a asp-action="Create" class="btn btn-cs-primary">
        <i class="bi bi-plus-lg me-1" aria-hidden="true"></i>Novo Visitante
    </a>
</div>

<div class="cs-card">
    <div class="cs-card-header d-flex justify-content-between align-items-center">
        <span>Lista</span>
        <span class="text-muted small">Total: @Model.Count()</span>
    </div>

    <div class="cs-card-body">
        @if (!Model.Any())
        {
            <div class="alert alert-info text-center mb-0">
                Nenhum visitante cadastrado.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 js-data-table">
                    <thead class="table-light">
                        <tr>
                            <th>Nome</th>
                            <th>CPF</th>
                            <th>Data/Hora Entrada</th>
                            <th>Data/Hora Saída</th>
                            <th class="text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Nome</td>
                                <td>@item.Cpf</td>
                                <td>
                                    @if (item.DataHoraEntrada.HasValue)
                                    {
                                        @item.DataHoraEntrada.Value.ToString("dd/MM/yyyy HH:mm")
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    @if (item.DataHoraSaida.HasValue)
                                    {
                                        @item.DataHoraSaida.Value.ToString("dd/MM/yyyy HH:mm")
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-cs-outline me-1" title="Detalhes"><i class="bi bi-eye" aria-hidden="true"></i></a>

                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-cs-outline me-1" title="Editar"><i class="bi bi-pencil" aria-hidden="true"></i></a>

                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-danger" title="Excluir"><i class="bi bi-trash" aria-hidden="true"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
