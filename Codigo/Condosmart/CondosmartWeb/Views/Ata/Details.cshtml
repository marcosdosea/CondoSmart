@model CondosmartWeb.Models.AtaViewModel
@{
    ViewData["Title"] = "Detalhes da Ata";
}

<div class="cs-card">
    <div class="cs-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-eye me-2" aria-hidden="true"></i>Detalhes</span>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-cs-outline btn-sm"><i class="bi bi-pencil me-2" aria-hidden="true"></i>Editar</a>
            <a asp-action="Index" class="btn btn-cs-outline btn-sm">↩ Voltar</a>
        </div>
    </div>

    <div class="cs-card-body">
        <div class="row g-3">
            <div class="col-12 col-lg-8">
                <div class="text-muted small">Título</div>
                <div class="fw-semibold">@Model.Titulo</div>
            </div>

            <div class="col-12 col-lg-4">
                <div class="text-muted small">Data da Reunião</div>
                <div class="fw-semibold">@Model.DataReuniao.ToString("dd/MM/yyyy")</div>
            </div>

            <div class="col-12">
                <div class="text-muted small">Temas</div>
                <div class="fw-semibold">@Model.Temas</div>
            </div>

            <div class="col-12">
                <div class="text-muted small">Conteudo</div>
                <div id="ataMarkdownDetalhes" class="fw-semibold cs-markdown-preview border rounded-4 p-3 bg-light" data-markdown="@Model.Conteudo"></div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.ArquivoCaminho))
            {
                <div class="col-12">
                    <div class="text-muted small">Arquivo anexado</div>
                    <a href="@Model.ArquivoCaminho" target="_blank" rel="noopener" class="btn btn-cs-outline btn-sm mt-1">
                        <i class="bi bi-file-earmark-arrow-down me-2" aria-hidden="true"></i>@(Model.ArquivoNomeOriginal ?? "Baixar arquivo")
                    </a>
                </div>
            }

            @if (Model.CreatedAt.HasValue)
            {
                <div class="col-12">
                    <div class="text-muted small">Criado em</div>
                    <div class="fw-semibold">@Model.CreatedAt.Value.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const container = document.getElementById('ataMarkdownDetalhes');
            if (!container || !window.marked) return;

            const markdown = container.dataset.markdown || '';
            container.innerHTML = markdown.trim()
                ? window.marked.parse(markdown)
                : 'Nenhuma observacao registrada para esta ata.';
        })();
    </script>
}
