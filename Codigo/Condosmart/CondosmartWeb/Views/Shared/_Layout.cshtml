@using Core.Identity
@inject Microsoft.AspNetCore.Identity.SignInManager<Core.Models.UsuarioSistema> SignInManager
@inject Microsoft.AspNetCore.Identity.UserManager<Core.Models.UsuarioSistema> UserManager
@{
	var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
	string Active(string controller) => string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) ? "active" : "";
	var isAdmin = User.IsInRole(Perfis.Admin);
	var isMorador = User.IsInRole(Perfis.Morador);
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - CondoSmart</title>

	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
	<link rel="stylesheet" href="https://cdn.datatables.net/2.3.2/css/dataTables.bootstrap5.min.css" />
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>
	<div class="cs-shell">
		<div id="csOverlay" class="cs-overlay" onclick="toggleSidebar(false)"></div>

		<aside id="csSidebar" class="cs-sidebar">
			<div class="cs-brand">
				<div class="cs-brand-badge"><i class="bi bi-buildings"></i></div>
				<div>
					<div class="cs-brand-title">CondoSmart</div>
					<small class="cs-brand-subtitle">Gest&atilde;o de condom&iacute;nios</small>
				</div>
			</div>

			<div class="cs-search">
				<input class="form-control" placeholder="Buscar no sistema" aria-label="Buscar no sistema" />
			</div>

			<nav class="cs-nav">
				@if (isAdmin)
				{
					<a class="@Active("Home")" asp-controller="Home" asp-action="Index">
						<span class="cs-nav-icon"><i class="bi bi-house-door"></i></span>
						<span>Home</span>
					</a>
					<a class="@Active("Condominio")" asp-controller="Condominio" asp-action="Index">
						<span class="cs-nav-icon"><i class="bi bi-buildings"></i></span>
						<span>Condom&iacute;nios</span>
					</a>
					<a class="@Active("UnidadesResidenciais")" asp-controller="UnidadesResidenciais" asp-action="Index">
						<span class="cs-nav-icon"><i class="bi bi-houses"></i></span>
						<span>Unidades Residenciais</span>
					</a>
					<a class="@Active("Sindico")" asp-controller="Sindico" asp-action="Index">
						<span class="cs-nav-icon"><i class="bi bi-person"></i></span>
						<span>S&iacute;ndico</span>
					</a>
					<a class="@Active("Morador")" asp-controller="Morador" asp-action="Index">
						<span class="cs-nav-icon"><i class="bi bi-people"></i></span>
						<span>Moradores</span>
					</a>
					<a class="@Active("Ata")" asp-controller="Ata" asp-action="Index">
						<span class="cs-nav-icon"><i class="bi bi-card-text"></i></span>
						<span>Atas</span>
					</a>
					<a class="@Active("Visitante")" asp-controller="Visitante" asp-action="Index">
						<span class="cs-nav-icon"><i class="bi bi-person-check"></i></span>
						<span>Visitantes</span>
					</a>
					<a class="@Active("Reserva")" asp-controller="Reserva" asp-action="Index">
						<span class="cs-nav-icon"><i class="bi bi-calendar3"></i></span>
						<span>Reservas</span>
					</a>
					<a class="@Active("Mensalidades")" asp-controller="Mensalidades" asp-action="Index">
						<span class="cs-nav-icon"><i class="bi bi-credit-card"></i></span>
						<span>Mensalidades</span>
					</a>
					<a class="@Active("AreaDeLazer")" asp-controller="AreaDeLazer" asp-action="Index">
						<span class="cs-nav-icon"><i class="bi bi-stars"></i></span>
						<span>&Aacute;reas de Lazer</span>
					</a>
				}
				else if (isMorador)
				{
					<a class="@Active("MoradorDashboard")" asp-controller="MoradorDashboard" asp-action="Index">
						<span class="cs-nav-icon"><i class="bi bi-speedometer2"></i></span>
						<span>Meu painel</span>
					</a>
					<a class="@Active("MoradorDashboard")" asp-controller="MoradorDashboard" asp-action="Index" asp-fragment="meus-dados">
						<span class="cs-nav-icon"><i class="bi bi-person-vcard"></i></span>
						<span>Meus dados</span>
					</a>
					<a class="@Active("MoradorDashboard")" asp-controller="MoradorDashboard" asp-action="Index" asp-fragment="minhas-mensalidades">
						<span class="cs-nav-icon"><i class="bi bi-receipt"></i></span>
						<span>Minhas mensalidades</span>
					</a>
					<a class="@Active("MoradorDashboard")" asp-controller="MoradorDashboard" asp-action="Index" asp-fragment="comunicados">
						<span class="cs-nav-icon"><i class="bi bi-megaphone"></i></span>
						<span>Comunicados</span>
					</a>
				}
			</nav>
		</aside>

		<div class="cs-main">
			<header class="cs-topbar">
				<div class="d-flex align-items-center gap-3">
					<button class="cs-menu-btn" type="button" onclick="toggleSidebar(true)" aria-label="Abrir menu">
						<i class="bi bi-list"></i>
					</button>
					<div>
						<div class="title">@ViewData["Title"]</div>
					</div>
				</div>

				<div class="cs-top-actions">
					@if (isAdmin)
					{
						<div class="cs-condo-select d-none d-xl-flex">
							<span>Condom&iacute;nio Jardim das Flores</span>
							<i class="bi bi-chevron-down"></i>
						</div>
					}
					else if (isMorador)
					{
						<div class="cs-condo-select d-none d-xl-flex">
							<span>&Aacute;rea do morador</span>
							<i class="bi bi-person-check"></i>
						</div>
					}

					<button class="cs-icon-btn cs-notification-btn" title="Notifica&ccedil;&otilde;es" aria-label="Notifica&ccedil;&otilde;es">
						<i class="bi bi-bell"></i>
						<span>3</span>
					</button>

					@if (SignInManager.IsSignedIn(User))
					{
						var usuario = await UserManager.GetUserAsync(User);
						var emailCompleto = UserManager.GetUserName(User) ?? "";
						string displayName;
						string iniciais;

						if (!string.IsNullOrWhiteSpace(usuario?.NomeCompleto))
						{
							var partes = usuario.NomeCompleto.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
							displayName = partes.Length >= 2 ? $"{partes[0]} {partes[^1]}" : partes[0];
							iniciais = partes.Length >= 2
								? $"{partes[0][0]}{partes[^1][0]}".ToUpper()
								: partes[0][0].ToString().ToUpper();
						}
						else
						{
							displayName = emailCompleto.Contains('@') ? emailCompleto.Split('@')[0] : emailCompleto;
							iniciais = displayName.Length > 0 ? displayName[0].ToString().ToUpper() : "U";
						}

						<div class="cs-user-chip" title="@emailCompleto">
							<div class="cs-user-avatar">@iniciais</div>
							<span class="cs-user-name">@displayName</span>
						</div>
						<form method="post" asp-area="Identity" asp-page="/Account/Logout" style="display:contents">
							<button type="submit" class="cs-icon-btn cs-logout-btn" title="Sair" aria-label="Sair">
								<i class="bi bi-box-arrow-right"></i>
							</button>
						</form>
					}
					else
					{
						<a asp-area="Identity" asp-page="/Account/Login" class="cs-btn-entrar">
							Entrar
						</a>
					}
				</div>
			</header>

			<main class="container py-4 py-lg-5">
				@RenderBody()
			</main>

			<footer class="text-muted py-3">
				<div class="container">
					&copy; 2026 - CondoSmart
				</div>
			</footer>
		</div>
	</div>

	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
	<script src="https://cdn.datatables.net/2.3.2/js/dataTables.min.js"></script>
	<script src="https://cdn.datatables.net/2.3.2/js/dataTables.bootstrap5.min.js"></script>
	<script src="~/js/site.js" asp-append-version="true"></script>

	<script>
		function toggleSidebar(open) {
			const sidebar = document.getElementById('csSidebar');
			const overlay = document.getElementById('csOverlay');
			if (!sidebar || !overlay) return;

			if (open) {
				sidebar.classList.add('open');
				overlay.classList.add('show');
			} else {
				sidebar.classList.remove('open');
				overlay.classList.remove('show');
			}
		}
	</script>

	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
